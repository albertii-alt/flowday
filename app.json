{
  "expo": {
    "name": "FlowDay",
    "slug": "flowday",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/flowday-icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "flowday",
    "splash": {
      "image": "./assets/flowday-onboard.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.flowday"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/flowday-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "package": "com.yourcompany.flowday"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7269b3a1-ce37-48d5-b7e8-ca9371a2620c"
      }
    }
  }
}
